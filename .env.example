# 飞书应用配置（必填）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 健康检查端口
PORT=3700

# pi 模型配置
PI_FEISHU_MODEL=google/gemini-2.5-flash-preview-05-06
PI_FEISHU_THINKING=off
PI_FEISHU_TIMEOUT=300000

# 目录配置
PI_FEISHU_WORKSPACES=./workspaces
PI_FEISHU_SESSIONS=./sessions

# 日志等级: debug | info | warn | error
PI_FEISHU_LOG_LEVEL=info
